{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Real-time camera event monitoring — MQTT Pipeline",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["mqtt", "camera", "iot", "influxdb"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Camera Events Pipeline",
  "uid": "camera-events",
  "version": 0,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Events",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "mqtt-influxdb" },
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "mqtt-influxdb" },
          "query": "from(bucket: \"camera_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"camera_events\")\n  |> filter(fn: (r) => r[\"_field\"] == \"confidence\")\n  |> group()\n  |> count()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Confidence",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
