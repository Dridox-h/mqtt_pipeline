            "gradientMode": "opacity",
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "mqtt-influxdb" },
          "query": "from(bucket: \"camera_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"camera_events\")\n  |> filter(fn: (r) => r[\"_field\"] == \"confidence\")\n  |> group(columns: [\"camera\"])\n  |> aggregateWindow(every: v.windowPeriod, fn: count, createEmpty: false)\n  |> yield(name: \"count\")",
          "refId": "A"
        }
      ]
