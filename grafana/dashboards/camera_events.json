          "query": "from(bucket: \"camera_events\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"camera_events\")\n  |> filter(fn: (r) => r[\"_field\"] == \"confidence\")\n  |> group(columns: [\"camera\"])\n  |> count()\n  |> group()\n  |> count()",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Events (last 5 min)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
